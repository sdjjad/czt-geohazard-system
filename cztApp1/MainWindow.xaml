<Window x:Class="cztApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:cztApp1.Views"
        mc:Ignorable="d"
        Title="长株潭地质灾害系统" Height="650" Width="1100"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Microsoft YaHei UI">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"
                            CornerRadius="8"
                            ResizeBorderThickness="5"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Brushes.xaml"/>
                <ResourceDictionary Source="Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="Styles/TabStyles.xaml"/>
                <ResourceDictionary Source="Styles/PanelStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="CaptionBtn" TargetType="Button">
                <Setter Property="Width" Value="40"/>
                <Setter Property="Height" Value="26"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="#555555"/>
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#E0E0E0"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- 下拉菜单样式：纯白 -->
            <Style TargetType="ContextMenu">
                <Setter Property="Background" Value="White"/>
                <Setter Property="Foreground" Value="#1A1A1A"/>
                <Setter Property="BorderBrush" Value="#C0C0C0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="HasDropShadow" Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContextMenu">
                            <Border Background="White" BorderBrush="#C0C0C0"
                                    BorderThickness="1" CornerRadius="3" Padding="2">
                                <StackPanel IsItemsHost="True" Background="White"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style TargetType="MenuItem">
                <Setter Property="Background" Value="White"/>
                <Setter Property="Foreground" Value="#1A1A1A"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Border x:Name="bd" Background="White"
                                    Padding="{TemplateBinding Padding}">
                                <TextBlock Text="{TemplateBinding Header}"
                                           Foreground="#1A1A1A" FontSize="12"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#F0F0F0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!-- 去掉 MenuItem 左侧 Icon 列 -->
            <Style TargetType="Menu">
                <Setter Property="Background" Value="White"/>
            </Style>

            <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource CaptionBtn}">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#E81123"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border x:Name="OuterBorder" Background="#F2F2F2" CornerRadius="8">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="6"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                        <Setter Property="CornerRadius" Value="0"/>
                        <Setter Property="Padding" Value="8"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Border.Effect>
            <DropShadowEffect Color="#20000000" BlurRadius="12" ShadowDepth="2" Opacity="0.3"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ====== 标题栏 ====== -->
            <Grid Grid.Row="0" Background="#F2F2F2"
                  MouseLeftButtonDown="TitleBar_Drag" Margin="12,6,12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid Margin="0,0,6,0">
                        <Ellipse Width="18" Height="18" Fill="#1565C0"/>
                        <TextBlock Text="&#xE1B3;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <Border Width="1" Height="14" Background="#D0D0D0" VerticalAlignment="Center" Margin="0,0,6,0"/>

                    <!-- Undo -->
                    <Grid Margin="0,0,1,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="UndoBtn" Style="{StaticResource QatBtn}"
                                ToolTip="撤销" Click="Undo_Click" Width="24" Height="22" Padding="3,0" IsEnabled="False">
                            <Image Source="/Resources/undo.png" Width="14" Height="14" Stretch="Uniform"/>
                        </Button>
                        <Button Grid.Column="1" x:Name="UndoDropBtn" Style="{StaticResource QatBtn}"
                                ToolTip="撤销记录" Click="UndoHistory_Click" Width="11" Height="22" Padding="1,0" IsEnabled="False">
                            <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="5" Foreground="#1A1A1A"/>
                        </Button>
                    </Grid>

                    <!-- Redo -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="RedoBtn" Style="{StaticResource QatBtn}"
                                ToolTip="重做" Click="Redo_Click" Width="24" Height="22" Padding="3,0" IsEnabled="False">
                            <Image Source="/Resources/redo.png" Width="14" Height="14" Stretch="Uniform"/>
                        </Button>
                        <Button Grid.Column="1" x:Name="RedoDropBtn" Style="{StaticResource QatBtn}"
                                ToolTip="重做记录" Click="RedoHistory_Click" Width="11" Height="22" Padding="1,0" IsEnabled="False">
                            <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="5" Foreground="#1A1A1A"/>
                        </Button>
                    </Grid>

                    <Border Width="1" Height="14" Background="#D0D0D0" VerticalAlignment="Center" Margin="4,0"/>

                    <!-- 视图下拉按钮 -->
                    <Button x:Name="ViewMenuBtn" Content="视图" FontSize="11"
                            Foreground="#1A1A1A" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Padding="6,2" Click="ViewMenu_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource CaptionBtn}" Content="&#xE921;" Click="Minimize_Click" ToolTip="最小化"/>
                    <Button x:Name="MaxBtn" Style="{StaticResource CaptionBtn}" Content="&#xE922;" Click="Maximize_Click" ToolTip="最大化"/>
                    <Button Style="{StaticResource CloseBtn}" Content="&#xE8BB;" Click="Close_Click" ToolTip="关闭"/>
                </StackPanel>
            </Grid>

            <!-- ====== Ribbon ====== -->
            <TabControl Grid.Row="1" Style="{StaticResource RibbonTC}" SelectedIndex="0">

                <!-- HOME: 数据管理 -->
                <TabItem Style="{StaticResource RibbonTabItem}" Header="数据管理">
                    <WrapPanel Orientation="Horizontal">
                        <Border Padding="8,3,10,3">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource RbnBtn}">
                                        <StackPanel>
                                            <Image Source="/Resources/folder.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="导入数据" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}">
                                        <StackPanel>
                                            <Image Source="/Resources/marker.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="地图操作" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}">
                                        <StackPanel>
                                            <Image Source="/Resources/search.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="空间查询" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}">
                                        <StackPanel>
                                            <Image Source="/Resources/combo-chart.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="空间分析" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}">
                                        <StackPanel>
                                            <Image Source="/Resources/edit.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="制图" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <TextBlock Style="{StaticResource GrpLbl}" Text="空间数据管理"/>
                            </StackPanel>
                        </Border>
                        <Border Padding="10,3,8,3">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource RbnBtn}">
                                        <StackPanel>
                                            <Image Source="/Resources/table.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="属性浏览" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}">
                                        <StackPanel>
                                            <Image Source="/Resources/search.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="属性查询" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}">
                                        <StackPanel>
                                            <Image Source="/Resources/settings.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="属性管理" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}">
                                        <StackPanel>
                                            <Image Source="/Resources/edit.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="制图" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <TextBlock Style="{StaticResource GrpLbl}" Text="属性数据管理"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </TabItem>

                <!-- 地质地震 -->
                <TabItem Style="{StaticResource RibbonTabItem}" Header="地质地震">
                    <WrapPanel Orientation="Horizontal">
                        <Border Padding="8,3">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource RbnBtn}" Click="Geo_Btn_Click">
                                        <StackPanel>
                                            <Image Source="/Resources/marker.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="地质构造" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}">
                                        <StackPanel>
                                            <Image Source="/Resources/combo-chart.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="地震分布" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}">
                                        <StackPanel>
                                            <Image Source="/Resources/warning-shield.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="地质灾害点" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}">
                                        <StackPanel>
                                            <Image Source="/Resources/book.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="风险区划" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <TextBlock Style="{StaticResource GrpLbl}" Text="地质地震数据"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </TabItem>

                <!-- 地形地貌 -->
                <TabItem Style="{StaticResource RibbonTabItem}" Header="地形地貌">
                    <WrapPanel Orientation="Horizontal">
                        <Border Padding="8,3">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource RbnBtn}" Click="Topo_Btn_Click">
                                        <StackPanel>
                                            <Image Source="/Resources/marker.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="DEM数据" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}">
                                        <StackPanel>
                                            <Image Source="/Resources/combo-chart.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="坡度分析" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}">
                                        <StackPanel>
                                            <Image Source="/Resources/compass.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="坡向分析" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}">
                                        <StackPanel>
                                            <Image Source="/Resources/combo-chart.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="等高线" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}">
                                        <StackPanel>
                                            <Image Source="/Resources/compass.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="三维地形" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <TextBlock Style="{StaticResource GrpLbl}" Text="地形地貌数据"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </TabItem>

                <!-- 土壤植被 -->
                <TabItem Style="{StaticResource RibbonTabItem}" Header="土壤植被">
                    <WrapPanel Orientation="Horizontal">
                        <Border Padding="8,3">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource RbnBtn}" Click="Veg_Btn_Click">
                                        <StackPanel>
                                            <Image Source="/Resources/soil.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="土壤类型" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}">
                                        <StackPanel>
                                            <Image Source="/Resources/leaf.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="植被覆盖" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}">
                                        <StackPanel>
                                            <Image Source="/Resources/building.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="土地利用" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}">
                                        <StackPanel>
                                            <Image Source="/Resources/water.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="水土流失" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <TextBlock Style="{StaticResource GrpLbl}" Text="土壤植被数据"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </TabItem>

                <!-- 专题制图 -->
                <TabItem Style="{StaticResource RibbonTabItem}" Header="专题制图">
                    <WrapPanel Orientation="Horizontal">
                        <Border Padding="8,3">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource RbnBtn}">
                                        <StackPanel>
                                            <Image Source="/Resources/print.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="地图输出" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}">
                                        <StackPanel>
                                            <Image Source="/Resources/book.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="图例设置" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}">
                                        <StackPanel>
                                            <Image Source="/Resources/settings.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="打印设置" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}">
                                        <StackPanel>
                                            <Image Source="/Resources/document.png" Width="22" Height="22" Stretch="Uniform"/>
                                            <TextBlock Text="报表生成" FontSize="10" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <TextBlock Style="{StaticResource GrpLbl}" Text="专题制图"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </TabItem>

            </TabControl>

            <!-- 主内容区 -->
            <Grid Grid.Row="2" x:Name="MainContentGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" MinWidth="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" MinWidth="300"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220" MinWidth="150"/>
                </Grid.ColumnDefinitions>

                <!-- 数据管理面板 -->
                <Border Grid.Column="0" Margin="6,2,0,4"
                        Style="{StaticResource PanelBorderStyle}"
                        MouseDown="DataPanel_GotFocus">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/><RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="数据管理"
                                       Style="{StaticResource PanelTitleStyle}"/>
                            <StackPanel Grid.Column="3" Orientation="Horizontal">
                                <Button Style="{StaticResource PanelIconBtnStyle}"
                                        Click="PanelOptions_Click" ToolTip="选项">
                                    <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="8" Foreground="#444444"/>
                                </Button>
                                <Button x:Name="AutoHideBtn"
                                        Style="{StaticResource PanelIconBtnStyle}"
                                        Click="AutoHide_Click" ToolTip="自动隐藏">
                                    <TextBlock Text="&#xE77A;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="10" Foreground="#444444"/>
                                </Button>
                                <Button Style="{StaticResource PanelIconBtnStyle}"
                                        Click="PanelClose_Click" ToolTip="关闭面板">
                                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="10" Foreground="#444444"/>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="1" x:Name="SearchBorder"
                                Background="White" BorderBrush="#D0D0D0"
                                BorderThickness="1" CornerRadius="3" Height="26" Margin="0,0,0,6"
                                MouseEnter="SearchBorder_MouseEnter"
                                MouseLeave="SearchBorder_MouseLeave"
                                GotFocus="SearchBorder_GotFocus"
                                LostFocus="SearchBorder_LostFocus"
                                MouseDown="SearchBorder_MouseDown">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <TextBlock Text="搜索" FontStyle="Italic" Foreground="#AAAAAA"
                                               VerticalAlignment="Center" Margin="6,0,0,0"
                                               IsHitTestVisible="False"
                                               Visibility="Visible" x:Name="SearchPlaceholder"/>
                                    <TextBox x:Name="SearchBox" BorderThickness="0"
                                             Background="Transparent" VerticalAlignment="Center"
                                             FontSize="10" Foreground="#1A1A1A"
                                             Padding="6,0,2,0"
                                             TextChanged="SearchBox_TextChanged"/>
                                </Grid>
                                <Button Grid.Column="1" x:Name="SearchBtn" Width="26" Height="24"
                                        Click="Search_Click" Margin="1" Padding="0"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                                    <TextBlock Text="&#xE11A;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                               Foreground="#555555"/>
                                </Button>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="2"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" x:Name="BtnSpatial" Content="空间数据管理"
                                    Click="SwitchToSpatial" Height="26" FontSize="10" Padding="8,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#1565C0"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Grid.Column="2" x:Name="BtnAttribute" Content="属性数据管理"
                                    Click="SwitchToAttribute" Height="26" FontSize="10" Padding="8,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#E8E8E8"/>
                                        <Setter Property="Foreground" Value="#555555"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>

                                                <TreeView Grid.Row="3" x:Name="DataTree" BorderThickness="0"
                                  Background="Transparent" FontSize="12">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="Foreground" Value="#333333"/>
                                    <Setter Property="Padding" Value="1,2"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TreeViewItem">
                                                <StackPanel>
                                                    <Border x:Name="Bd" Background="Transparent"
                                                            Padding="{TemplateBinding Padding}" CornerRadius="2">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="16"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <ToggleButton x:Name="Expander" Grid.Column="0"
                                                                          ClickMode="Press"
                                                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                                          Width="14" Height="14" Margin="0,0,2,0">
                                                                <ToggleButton.Template>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border Background="Transparent" Width="14" Height="14">
                                                                            <TextBlock x:Name="Arrow" Text="▶"
                                                                                       FontSize="8" Foreground="#666666"
                                                                                       HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsChecked" Value="True">
                                                                                <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </ToggleButton.Template>
                                                            </ToggleButton>
                                                            <ContentPresenter x:Name="PART_Header" Grid.Column="1"
                                                                              ContentSource="Header"
                                                                              VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                    <ItemsPresenter x:Name="ItemsHost" Margin="16,0,0,0"
                                                                    Visibility="Collapsed"/>
                                                </StackPanel>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsExpanded" Value="True">
                                                        <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                                                    </Trigger>
                                                    <Trigger Property="HasItems" Value="False">
                                                        <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                                    </Trigger>
                                                    <Trigger SourceName="Bd" Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#F0F0F0"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#E6EDF5"/>
                                                        <Setter Property="Foreground" Value="#1565C0"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TreeView.ItemContainerStyle>
                        </TreeView>
                    </Grid>
                </Border>

                <GridSplitter x:Name="LeftSplitter" Grid.Column="1" Width="4"
                              Background="Transparent"
                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext"/>

                <!-- 地图视图 / 分析面板 -->
                <Border Grid.Column="2" Background="White">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- Map header -->
                        <Border Grid.Row="0" Background="White" Padding="8,5">
                            <TextBlock Text="地图视图" FontWeight="SemiBold" FontSize="12" Foreground="#1A1A1A"/>
                        </Border>
                        <!-- Map content area -->
                        <Grid Grid.Row="1">
                            <views:MapView x:Name="MapViewControl" />
                            <Grid x:Name="AnalysisHost"/>
                        </Grid>
                    </Grid>
                </Border>

                <GridSplitter x:Name="RightOuterSplitter" Grid.Column="3" Width="4"
                              Background="Transparent"
                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext"/>

                <!-- 右侧面板区：图层面板 + 分隔条 + 符号系统面板 -->
                <Grid Grid.Column="4" Margin="0,2,6,4" x:Name="RightPanelGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="100"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                <!-- 图层面板 -->
                <Border Grid.Row="0"
                        Style="{StaticResource PanelBorderStyle}"
                        MouseDown="LayerPanel_GotFocus">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="图层"
                                       Style="{StaticResource PanelTitleStyle}"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Button Style="{StaticResource PanelIconBtnStyle}"
                                        Click="LayerOptions_Click" ToolTip="选项">
                                    <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="8" Foreground="#444444"/>
                                </Button>
                                <Button Style="{StaticResource PanelIconBtnStyle}"
                                        Click="LayerAutoHide_Click" ToolTip="自动隐藏">
                                    <TextBlock Text="&#xE77A;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="10" Foreground="#444444"/>
                                </Button>
                                <Button Style="{StaticResource PanelIconBtnStyle}"
                                        Click="LayerPanelClose_Click" ToolTip="关闭面板">
                                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="10" Foreground="#444444"/>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <TreeView Grid.Row="1" x:Name="LayerTreeView"
                                  Background="Transparent" BorderThickness="0"
                                  FontSize="11" AllowDrop="True"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="False"/>
                                    <Setter Property="Padding" Value="1,2"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TreeViewItem">
                                                <StackPanel>
                                                    <Border x:Name="Bd" Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            BorderThickness="1" CornerRadius="2"
                                                            Padding="2,2">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="16"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <ToggleButton x:Name="Expander" Grid.Column="0"
                                                                          ClickMode="Press"
                                                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                                          Width="14" Height="14">
                                                                <ToggleButton.Template>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border Background="Transparent"
                                                                                Width="14" Height="14">
                                                                            <TextBlock x:Name="Arrow" Text="▶"
                                                                                       FontSize="8" Foreground="#666"
                                                                                       HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsChecked" Value="True">
                                                                                <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </ToggleButton.Template>
                                                            </ToggleButton>
                                                            <ContentPresenter x:Name="PART_Header"
                                                                              Grid.Column="2"
                                                                              ContentSource="Header"
                                                                              VerticalAlignment="Center"
                                                                              Margin="2,0,0,0"/>
                                                        </Grid>
                                                    </Border>
                                                    <ItemsPresenter x:Name="ItemsHost"
                                                                    Margin="16,0,0,0"
                                                                    Visibility="Collapsed"/>
                                                </StackPanel>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsExpanded" Value="True">
                                                        <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                                                    </Trigger>
                                                    <Trigger Property="HasItems" Value="False">
                                                        <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition SourceName="Bd" Property="IsMouseOver" Value="True"/>
                                                            <Condition Property="IsSelected" Value="False"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="Bd" Property="Background" Value="#E6EDF5"/>
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="Transparent"/>
                                                    </MultiTrigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#E6EDF5"/>
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#1565C0"/>
                                                        <Setter Property="Foreground" Value="#1565C0"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Symbols}">
                                    <HierarchicalDataTemplate.ItemTemplate>
                                        <DataTemplate>
                                            <ContentControl Cursor="Hand"
                                                            Background="Transparent"
                                                            Margin="8,2,0,2"
                                                            PreviewMouseLeftButtonDown="SymbolItem_Click"
                                                            Content="{Binding Converter={x:Static views:SymbolPreviewConverter.Instance}}"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </HierarchicalDataTemplate.ItemTemplate>
                                    <Grid Background="Transparent">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  VerticalAlignment="Center"
                                                  IsChecked="{Binding IsVisible, Mode=TwoWay}"
                                                  Width="16" Height="16" Margin="2,0,6,0"
                                                  Checked="LayerCheckBox_Changed"
                                                  Unchecked="LayerCheckBox_Changed"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                   VerticalAlignment="Center"
                                                   Foreground="#333"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>

                    </Grid>
                </Border>

                <!-- 图层面板与符号面板之间的分隔条 -->
                <GridSplitter Grid.Row="1" x:Name="RightSplitter" Height="4"
                              HorizontalAlignment="Stretch" VerticalAlignment="Center"
                              Background="Transparent" ResizeBehavior="PreviousAndNext"
                              Visibility="Collapsed"/>

                <!-- 符号系统面板（独立面板，默认隐藏） -->
                <Border Grid.Row="2" x:Name="SymbolPanelHost" Visibility="Collapsed"
                        Style="{StaticResource PanelBorderStyle}" Margin="0,4,0,0"
                        MouseDown="SymbolPanel_GotFocus">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="SymbolPanelTitle"
                                       Text="符号系统"
                                       Style="{StaticResource PanelTitleStyle}"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Button Style="{StaticResource PanelIconBtnStyle}"
                                        Click="SymbolOptions_Click" ToolTip="选项">
                                    <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="8" Foreground="#444444"/>
                                </Button>
                                <Button Style="{StaticResource PanelIconBtnStyle}"
                                        Click="SymbolAutoHide_Click" ToolTip="自动隐藏">
                                    <TextBlock Text="&#xE77A;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="10" Foreground="#444444"/>
                                </Button>
                                <Button Style="{StaticResource PanelIconBtnStyle}"
                                        Click="SymbolPanelClose_Click" ToolTip="关闭面板">
                                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="10" Foreground="#444444"/>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- ArcGIS Pro 风格符号编辑器 -->
                        <StackPanel Grid.Row="1" x:Name="SymbolEditorHost" Margin="0,0,0,4">
                            <!-- 符号预览 -->
                            <Border x:Name="SymbolPreviewBorder" Background="White"
                                    BorderBrush="#D0D0D0" BorderThickness="1"
                                    Height="60" Margin="0,4,0,8" CornerRadius="3">
                                <Grid x:Name="SymbolPreviewHost"/>
                            </Border>

                            <!-- 符号属性 -->
                            <Grid x:Name="SymbolPropsGrid" Margin="0,2,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 符号面板与地理处理面板之间的分隔条 -->
                <GridSplitter Grid.Row="3" x:Name="GeoSplitter" Height="4"
                              HorizontalAlignment="Stretch" VerticalAlignment="Center"
                              Background="Transparent" ResizeBehavior="PreviousAndNext"
                              Visibility="Collapsed"/>

                <!-- 地理处理面板 -->
                <Border Grid.Row="4" x:Name="GeoPanelHost" Visibility="Collapsed"
                        Style="{StaticResource PanelBorderStyle}" Margin="0,4,0,0"
                        MouseDown="GeoPanel_GotFocus">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="地理处理"
                                       Style="{StaticResource PanelTitleStyle}"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Button Style="{StaticResource PanelIconBtnStyle}"
                                        Click="GeoOptions_Click" ToolTip="选项">
                                    <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="8" Foreground="#444444"/>
                                </Button>
                                <Button Style="{StaticResource PanelIconBtnStyle}"
                                        Click="GeoAutoHide_Click" ToolTip="自动隐藏">
                                    <TextBlock Text="&#xE77A;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="10" Foreground="#444444"/>
                                </Button>
                                <Button Style="{StaticResource PanelIconBtnStyle}"
                                        Click="GeoPanelClose_Click" ToolTip="关闭面板">
                                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="10" Foreground="#444444"/>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <ContentControl Grid.Row="1" x:Name="GeoPanelContent"
                                        Margin="0,0,0,4"/>
                    </Grid>
                </Border>
            </Grid>
            </Grid>

            <!-- 状态栏 -->
            <StatusBar Grid.Row="3" Background="#F2F2F2" Padding="6,2" FontSize="10">
                <StatusBar.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                        </Grid>
                    </ItemsPanelTemplate>
                </StatusBar.ItemsPanel>
                <StatusBarItem Grid.Column="0">
                    <TextBlock x:Name="StatusBar1" Text="就绪" Foreground="#555555"/>
                </StatusBarItem>
                <StatusBarItem Grid.Column="1">
                    <TextBlock x:Name="StatusScale" Text="比例 1:50000" Foreground="#555555" Margin="6,0"/>
                </StatusBarItem>
                <StatusBarItem Grid.Column="2">
                    <TextBlock x:Name="StatusCoord" Text="113.00° E  27.90° N" Foreground="#555555" Margin="6,0"/>
                </StatusBarItem>
            </StatusBar>
        </Grid>
    </Border>
</Window>
