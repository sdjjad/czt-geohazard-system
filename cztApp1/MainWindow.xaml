<Window x:Class="cztApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:cztApp1.Views"
        xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
        mc:Ignorable="d"
        Title="长株潭地质灾害发育特征专题系统——土壤植被" Height="650" Width="1100"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Microsoft YaHei UI">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"
                            CornerRadius="8"
                            ResizeBorderThickness="5"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Brushes.xaml"/>
                <ResourceDictionary Source="Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="Styles/TabStyles.xaml"/>
                <ResourceDictionary Source="Styles/PanelStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="CaptionBtn" TargetType="Button">
                <Setter Property="Width" Value="40"/>
                <Setter Property="Height" Value="26"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="#555555"/>
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#E0E0E0"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- 下拉菜单样式：纯白 -->
            <Style TargetType="ContextMenu">
                <Setter Property="Background" Value="White"/>
                <Setter Property="Foreground" Value="#1A1A1A"/>
                <Setter Property="BorderBrush" Value="#C0C0C0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="HasDropShadow" Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContextMenu">
                            <Border Background="White" BorderBrush="#C0C0C0"
                                    BorderThickness="1" CornerRadius="3" Padding="2">
                                <StackPanel IsItemsHost="True" Background="White"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style TargetType="MenuItem">
                <Setter Property="Background" Value="White"/>
                <Setter Property="Foreground" Value="#1A1A1A"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Border x:Name="bd" Background="White"
                                    Padding="{TemplateBinding Padding}">
                                <TextBlock Text="{TemplateBinding Header}"
                                           Foreground="#1A1A1A" FontSize="12"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#F0F0F0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!-- 去掉 MenuItem 左侧 Icon 列 -->
            <Style TargetType="Menu">
                <Setter Property="Background" Value="White"/>
            </Style>

            <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource CaptionBtn}">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#E81123"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- DataTree ItemContainerStyle -->
            <Style x:Key="DataTreeItemStyle" TargetType="TreeViewItem">
                <Setter Property="Foreground" Value="#333333"/>
                <Setter Property="Padding" Value="1,2"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TreeViewItem">
                            <StackPanel>
                                <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}" CornerRadius="2">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <ToggleButton x:Name="Expander" Grid.Column="0" ClickMode="Press"
                                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                      Width="14" Height="14" Margin="0,0,2,0">
                                            <ToggleButton.Template>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border Background="Transparent" Width="14" Height="14">
                                                        <TextBlock x:Name="Arrow" Text="▶" FontSize="8" Foreground="#666666"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </ToggleButton.Template>
                                        </ToggleButton>
                                        <ContentPresenter x:Name="PART_Header" Grid.Column="1" ContentSource="Header" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <ItemsPresenter x:Name="ItemsHost" Margin="16,0,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsExpanded" Value="True">
                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                                </Trigger>
                                <Trigger Property="HasItems" Value="False">
                                    <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                </Trigger>
                                <Trigger SourceName="Bd" Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#BBDEFB"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#E3F2FD"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#0D47A1"/>
                                    <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
                                    <Setter Property="Foreground" Value="#0D47A1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- LayerTreeView ItemContainerStyle -->
            <Style x:Key="LayerTreeItemStyle" TargetType="TreeViewItem">
                <Setter Property="IsExpanded" Value="False"/>
                <Setter Property="Padding" Value="1,2"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TreeViewItem">
                            <StackPanel>
                                <Border x:Name="Bd" Background="Transparent" BorderBrush="Transparent"
                                        BorderThickness="1" CornerRadius="2" Padding="2,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="16"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ToggleButton x:Name="Expander" Grid.Column="0" ClickMode="Press"
                                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                      Width="14" Height="14">
                                            <ToggleButton.Template>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border Background="Transparent" Width="14" Height="14">
                                                        <TextBlock x:Name="Arrow" Text="▶" FontSize="8" Foreground="#666"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </ToggleButton.Template>
                                        </ToggleButton>
                                        <ContentPresenter x:Name="PART_Header" Grid.Column="2" ContentSource="Header"
                                                          VerticalAlignment="Center" Margin="2,0,0,0"/>
                                    </Grid>
                                </Border>
                                <ItemsPresenter x:Name="ItemsHost" Margin="16,0,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsExpanded" Value="True">
                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                                </Trigger>
                                <Trigger Property="HasItems" Value="False">
                                    <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition SourceName="Bd" Property="IsMouseOver" Value="True"/>
                                        <Condition Property="IsSelected" Value="False"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Bd" Property="Background" Value="#BBDEFB"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="Transparent"/>
                                </MultiTrigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#E3F2FD"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#0D47A1"/>
                                    <Setter Property="Foreground" Value="#0D47A1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- LayerTreeView ItemTemplate -->
            <HierarchicalDataTemplate x:Key="LayerTreeTemplate" ItemsSource="{Binding Symbols}">
                <HierarchicalDataTemplate.ItemTemplate>
                    <DataTemplate>
                        <ContentControl Cursor="Hand" Background="Transparent" Margin="8,2,0,2"
                                        PreviewMouseLeftButtonDown="SymbolItem_Click"
                                        Content="{Binding Converter={x:Static views:SymbolPreviewConverter.Instance}}"
                                        HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </DataTemplate>
                </HierarchicalDataTemplate.ItemTemplate>
                <Grid Background="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" VerticalAlignment="Center"
                              IsChecked="{Binding IsVisible, Mode=TwoWay}" Width="16" Height="16" Margin="2,0,6,0"
                              Checked="LayerCheckBox_Changed" Unchecked="LayerCheckBox_Changed"/>
                    <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                               Foreground="#333" TextTrimming="CharacterEllipsis"
                               Cursor="Hand"
                               MouseLeftButtonDown="LayerName_Click"/>
                </Grid>
            </HierarchicalDataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Border x:Name="OuterBorder" Background="#F2F2F2" CornerRadius="8">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="6"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                        <Setter Property="CornerRadius" Value="0"/>
                        <Setter Property="Padding" Value="8"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Border.Effect>
            <DropShadowEffect Color="#20000000" BlurRadius="12" ShadowDepth="2" Opacity="0.3"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ====== 标题栏 ====== -->
            <Grid Grid.Row="0" Background="#F2F2F2"
                  MouseLeftButtonDown="TitleBar_Drag" Margin="12,6,12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid Margin="0,0,6,0">
                        <Ellipse Width="18" Height="18" Fill="#1565C0"/>
                        <TextBlock Text="&#xE1B3;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <Border Width="1" Height="14" Background="#D0D0D0" VerticalAlignment="Center" Margin="0,0,6,0"/>

                    <!-- Undo -->
                    <Grid Margin="0,0,1,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="UndoBtn" Style="{StaticResource QatBtn}"
                                ToolTip="撤销" Click="Undo_Click" Width="24" Height="22" Padding="3,0" IsEnabled="False">
                            <Image Source="/Resources/undo.png" Width="14" Height="14" Stretch="Uniform"/>
                        </Button>
                        <Button Grid.Column="1" x:Name="UndoDropBtn" Style="{StaticResource QatBtn}"
                                ToolTip="撤销记录" Click="UndoHistory_Click" Width="11" Height="22" Padding="1,0" IsEnabled="False">
                            <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="5" Foreground="#1A1A1A"/>
                        </Button>
                    </Grid>

                    <!-- Redo -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="RedoBtn" Style="{StaticResource QatBtn}"
                                ToolTip="重做" Click="Redo_Click" Width="24" Height="22" Padding="3,0" IsEnabled="False">
                            <Image Source="/Resources/redo.png" Width="14" Height="14" Stretch="Uniform"/>
                        </Button>
                        <Button Grid.Column="1" x:Name="RedoDropBtn" Style="{StaticResource QatBtn}"
                                ToolTip="重做记录" Click="RedoHistory_Click" Width="11" Height="22" Padding="1,0" IsEnabled="False">
                            <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="5" Foreground="#1A1A1A"/>
                        </Button>
                    </Grid>

                    <Border Width="1" Height="14" Background="#D0D0D0" VerticalAlignment="Center" Margin="4,0"/>

                    <!-- 视图下拉按钮 -->
                    <Button x:Name="ViewMenuBtn" Content="视图" FontSize="11"
                            Foreground="#1A1A1A" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Padding="6,2" Click="ViewMenu_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource CaptionBtn}" Content="&#xE921;" Click="Minimize_Click" ToolTip="最小化"/>
                    <Button x:Name="MaxBtn" Style="{StaticResource CaptionBtn}" Content="&#xE922;" Click="Maximize_Click" ToolTip="最大化"/>
                    <Button Style="{StaticResource CloseBtn}" Content="&#xE8BB;" Click="Close_Click" ToolTip="关闭"/>
                </StackPanel>
            </Grid>

            <!-- ====== Ribbon ====== -->
            <TabControl Grid.Row="1" Style="{StaticResource RibbonTC}" SelectedIndex="0">

                <!-- █████ 数据管理 █████ -->
                <TabItem Style="{StaticResource RibbonTabItem}" Header="数据管理">
                    <WrapPanel Orientation="Horizontal">
                        <!-- 空间数据组 -->
                        <Border Padding="8,4,2,4">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource RbnBtn}" Click="OpenTool_Click" Tag="ImportData">
                                        <StackPanel>
                                            <Viewbox Width="20" Height="18" Margin="0,0,0,2">
                                                <Canvas Width="20" Height="18">
                                                    <Path Fill="#1565C0" Data="M0,3 L0,15 L20,15 L20,5 L8,5 L6,3 Z"/>
                                                    <Path Data="M7,7 L13,7 L13,12 L7,12 Z M10,6 L10,13 M7,9.5 L13,9.5" Stroke="White" StrokeThickness="1.5"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Style="{StaticResource RbnLabel}" Text="导入数据"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}" Click="OpenTool_Click" Tag="SpatialQuery">
                                        <StackPanel>
                                            <Viewbox Width="20" Height="20" Margin="0,0,0,2">
                                                <Canvas Width="20" Height="20">
                                                    <Path Fill="#1565C0" Data="M1,2 L13,2 L13,10 L1,10 Z M10,9 L18,17 L15,18 L8,11 Z"/>
                                                    <Path Fill="White" Data="M3,4 L7,4 L7,7 L3,7 Z"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Style="{StaticResource RbnLabel}" Text="空间查询"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}" Click="OpenTool_Click" Tag="SpatialAnalysis">
                                        <StackPanel>
                                            <Viewbox Width="20" Height="20" Margin="0,0,0,2">
                                                <Canvas Width="20" Height="20">
                                                    <Path Fill="#90CAF9" Data="M2,2 L16,2 L16,7 L2,7 Z"/>
                                                    <Path Fill="#1565C0" Data="M1,7 L18,7 L18,12 L1,12 Z"/>
                                                    <Path Fill="#64B5F6" Data="M4,12 L14,12 L14,17 L4,17 Z"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Style="{StaticResource RbnLabel}" Text="空间分析"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}" Click="OpenTool_Click" Tag="Mapping">
                                        <StackPanel>
                                            <Viewbox Width="20" Height="20" Margin="0,0,0,2">
                                                <Canvas Width="20" Height="20">
                                                    <Path Fill="#1565C0" Data="M3,4 L17,4 L17,16 L3,16 Z"/>
                                                    <Path Data="M10,8 L14,12 M10,8 L6,14 M10,8 L14,8 L10,4" Stroke="White" StrokeThickness="1.5"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Style="{StaticResource RbnLabel}" Text="制图"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <TextBlock Style="{StaticResource GrpLbl}" Text="空间数据"/>
                            </StackPanel>
                        </Border>
                        <!-- 分隔线 -->
                        <Border Style="{StaticResource RbnSeparator}"/>
                        <!-- 属性数据组 -->
                        <Border Padding="2,4,8,4">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource RbnBtn}" Click="OpenTool_Click" Tag="AttributeBrowse">
                                        <StackPanel>
                                            <Viewbox Width="20" Height="18" Margin="0,0,0,2">
                                                <Canvas Width="20" Height="18">
                                                    <Path Fill="#1565C0" Data="M0,2 L20,2 L20,16 L0,16 Z"/>
                                                    <Path Data="M0,7 L20,7 M7,2 L7,16 M0,12 L20,12" Stroke="White" StrokeThickness="1.2"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Style="{StaticResource RbnLabel}" Text="属性浏览"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}" Click="OpenTool_Click" Tag="AttributeQuery">
                                        <StackPanel>
                                            <Viewbox Width="20" Height="20" Margin="0,0,0,2">
                                                <Canvas Width="20" Height="20">
                                                    <Path Fill="#1565C0" Data="M2,2 L18,2 L12,11 L12,18 L8,14 L8,11 Z"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Style="{StaticResource RbnLabel}" Text="属性查询"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}" Click="OpenTool_Click" Tag="AttributeManage">
                                        <StackPanel>
                                            <Viewbox Width="18" Height="18" Margin="0,0,0,2">
                                                <Canvas Width="18" Height="18">
                                                    <Path Fill="#1565C0" Data="M3,13 L5,15 L14,4 L12,2 Z M2,14 L3.5,17 L6.5,15.5 Z"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Style="{StaticResource RbnLabel}" Text="属性管理"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <TextBlock Style="{StaticResource GrpLbl}" Text="属性数据"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </TabItem>

                <!-- █████ 土壤植被 █████ -->
                <TabItem Style="{StaticResource RibbonTabItem}" Header="土壤植被">
                    <WrapPanel Orientation="Horizontal">
                        <Border Padding="8,4">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource RbnBtn}" Click="OpenTool_Click" Tag="SoilTypeAnalysis">
                                        <StackPanel>
                                            <Viewbox Width="20" Height="20" Margin="0,0,0,2">
                                                <Canvas Width="20" Height="20">
                                                    <Path Fill="#795548" Data="M2,2 L18,2 L18,18 L2,18 Z"/>
                                                    <Path Data="M2,5 Q6,4 10,6 Q14,7 18,5 M2,9 Q6,10 10,8 Q14,7 18,9 M2,13 Q6,12 10,14 Q14,15 18,13" Stroke="#A1887F" StrokeThickness="1"/>
                                                    <Path Data="M8,2 L8,0 M10,2 L10,-1 M12,2 L12,0" Stroke="#4CAF50" StrokeThickness="1.2"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Style="{StaticResource RbnLabel}" Text="土壤类型"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}" Click="OpenTool_Click" Tag="SoilMoisture">
                                        <StackPanel>
                                            <Viewbox Width="18" Height="20" Margin="0,0,0,2">
                                                <Canvas Width="18" Height="20">
                                                    <Path Fill="#0288D1" Data="M9,0 C4,7 1,11 1,15 C1,18 3,20 9,20 C15,20 17,18 17,15 C17,11 14,7 9,0 Z"/>
                                                    <Path Fill="#B3E5FC" Data="M7,15 Q9,12 11,15 Q10,17 7,15"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Style="{StaticResource RbnLabel}" Text="土壤湿度"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}" Click="OpenTool_Click" Tag="VegType">
                                        <StackPanel>
                                            <Viewbox Width="20" Height="20" Margin="0,0,0,2">
                                                <Canvas Width="20" Height="20">
                                                    <Path Fill="#2E7D32" Data="M10,1 C18,3 19,10 10,19 C1,10 2,3 10,1 Z"/>
                                                    <Path Data="M10,1 L10,19 M10,7 L16,13 M10,12 L5,16" Stroke="#4CAF50" StrokeThickness="0.8"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Style="{StaticResource RbnLabel}" Text="植被类型"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}" Click="OpenTool_Click" Tag="VegCoverage">
                                        <StackPanel>
                                            <Viewbox Width="20" Height="20" Margin="0,0,0,2">
                                                <Canvas Width="20" Height="20">
                                                    <Path Fill="#A5D6A7" Data="M1,2 L13,2 L13,14 L1,14 Z"/>
                                                    <Path Data="M1,2 L1,14 M4,2 L4,14 M7,2 L7,14 M10,2 L10,14 M13,2 L13,14 M1,2 L13,2 M1,6 L13,6 M1,10 L13,10 M1,14 L13,14" Stroke="#2E7D32" StrokeThickness="0.5"/>
                                                    <Path Fill="#2E7D32" Data="M1,2 L5,2 L5,6 L1,6 Z M7,2 L9,2 L9,4 L7,4 Z M3,8 L7,8 L7,10 L3,10 Z"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Style="{StaticResource RbnLabel}" Text="植被覆盖度"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}" Click="OpenTool_Click" Tag="NDVI">
                                        <StackPanel>
                                            <Viewbox Width="20" Height="18" Margin="0,0,0,2">
                                                <Canvas Width="20" Height="18">
                                                    <Path Data="M0,16 L4,12 L7,13 L10,5 L13,7 L16,1 L20,4" Stroke="#E53935" StrokeThickness="1.5"/>
                                                    <Path Data="M0,18 L20,18" Stroke="#BDBDBD" StrokeThickness="0.5"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Style="{StaticResource RbnLabel}" Text="NDVI"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <TextBlock Style="{StaticResource GrpLbl}" Text="土壤植被指标分析"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </TabItem>

                <!-- █████ 专题制图 █████ -->
                <TabItem Style="{StaticResource RibbonTabItem}" Header="专题制图">
                    <WrapPanel Orientation="Horizontal">
                        <Border Padding="8,4">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource RbnBtn}" Click="OpenTool_Click" Tag="StatChart">
                                        <StackPanel>
                                            <Viewbox Width="20" Height="20" Margin="0,0,0,2">
                                                <Canvas Width="20" Height="20">
                                                    <Path Data="M0,18 L20,18" Stroke="#1565C0" StrokeThickness="1.2"/>
                                                    <Path Fill="#1565C0" Data="M2,18 L2,8 L5,8 L5,18 Z M6,18 L6,4 L9,4 L9,18 Z M10,18 L10,11 L13,11 L13,18 Z M14,18 L14,3 L17,3 L17,18 Z"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Style="{StaticResource RbnLabel}" Text="统计图"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}" Click="OpenTool_Click" Tag="StatTable">
                                        <StackPanel>
                                            <Viewbox Width="20" Height="18" Margin="0,0,0,2">
                                                <Canvas Width="20" Height="18">
                                                    <Path Fill="#1565C0" Data="M0,0 L20,0 L20,16 L0,16 Z"/>
                                                    <Path Fill="#90CAF9" Data="M0,0 L20,0 L20,4 L0,4 Z"/>
                                                    <Path Data="M6,0 L6,16 M13,0 L13,16 M0,8 L20,8 M0,12 L20,12" Stroke="White" StrokeThickness="1"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Style="{StaticResource RbnLabel}" Text="统计表"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RbnBtn}" Click="OpenTool_Click" Tag="ThematicMap">
                                        <StackPanel>
                                            <Viewbox Width="20" Height="20" Margin="0,0,0,2">
                                                <Canvas Width="20" Height="20">
                                                    <Path Fill="#1565C0" Data="M2,3 L16,3 L16,14 L2,14 Z"/>
                                                    <Path Data="M4,6 L8,6 L8,9 L4,9 Z M10,6 L14,6 L14,9 L10,9 Z M4,10 L8,10 L8,12 L4,12 Z" Stroke="White" StrokeThickness="0.8"/>
                                                    <Path Fill="#E53935" Data="M17,5 L19,2 L18,5 Z"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Style="{StaticResource RbnLabel}" Text="专题图"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <TextBlock Style="{StaticResource GrpLbl}" Text="成果输出"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </TabItem>

            </TabControl>

            <!-- 主内容区：AvalonDock 停靠面板系统 -->
            <avalonDock:DockingManager Grid.Row="2" x:Name="DockManager">
                <avalonDock:LayoutRoot>
                    <avalonDock:LayoutPanel Orientation="Horizontal">

                        <!-- ====== 左侧：数据面板 ====== -->
                        <avalonDock:LayoutAnchorablePane DockWidth="220" DockMinWidth="150">
                            <avalonDock:LayoutAnchorable x:Name="DataPanelAnchor" Title="数据管理" CanClose="False" ContentId="DataPanel">
                                <Border Margin="0" Style="{StaticResource PanelBorderStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- 文件夹连接 -->
                                        <Border Grid.Row="0" Background="White" BorderBrush="#D0D0D0"
                                                BorderThickness="1" CornerRadius="3" Margin="0,0,0,4" Padding="4,3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Content="📂" Width="24" Height="22" FontSize="11"
                                                        Click="ConnectFolder_Click" Background="#E8E8E8" BorderThickness="0"
                                                        Cursor="Hand" ToolTip="连接空间数据文件夹"/>
                                                <TextBlock Grid.Column="1" x:Name="FolderPathLabel"
                                                           Text="点击📂连接空间数据文件夹..." FontSize="9"
                                                           Foreground="#999" VerticalAlignment="Center"
                                                           Margin="4,0" TextTrimming="CharacterEllipsis"/>
                                                <Button Grid.Column="2" Content="🔄" Width="24" Height="22" FontSize="11"
                                                        Click="RefreshFolder_Click" Background="#E8E8E8"
                                                        BorderThickness="0" Cursor="Hand" Margin="2,0,0,0"
                                                        ToolTip="刷新文件夹"/>
                                            </Grid>
                                        </Border>

                                        <!-- 生成属性表 -->
                                        <Button Grid.Row="1" x:Name="BtnGenAttr" Content="📋 自动生成属性表(CSV)"
                                                Height="26" FontSize="10" Margin="0,0,0,4"
                                                Background="#43A047" Foreground="White" BorderThickness="0"
                                                Cursor="Hand" Click="GenerateAttrTables_Click" IsEnabled="False"
                                                ToolTip="扫描所有shp，读取DBF属性，在属性数据文件夹中生成CSV"/>

                                        <Border Grid.Row="2" x:Name="SearchBorder" Background="White" BorderBrush="#D0D0D0"
                                                BorderThickness="1" CornerRadius="3" Height="26" Margin="0,0,0,6"
                                                MouseEnter="SearchBorder_MouseEnter" MouseLeave="SearchBorder_MouseLeave"
                                                GotFocus="SearchBorder_GotFocus" LostFocus="SearchBorder_LostFocus"
                                                MouseDown="SearchBorder_MouseDown">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <Grid Grid.Column="0">
                                                    <TextBlock Text="搜索" FontStyle="Italic" Foreground="#AAAAAA" VerticalAlignment="Center"
                                                               Margin="6,0,0,0" IsHitTestVisible="False" Visibility="Visible" x:Name="SearchPlaceholder"/>
                                                    <TextBox x:Name="SearchBox" BorderThickness="0" Background="Transparent"
                                                             VerticalAlignment="Center" FontSize="10" Foreground="#1A1A1A"
                                                             Padding="6,0,2,0" TextChanged="SearchBox_TextChanged"/>
                                                </Grid>
                                                <Button Grid.Column="1" x:Name="SearchBtn" Width="26" Height="24"
                                                        Click="Search_Click" Margin="1" Padding="0"
                                                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                                                    <TextBlock Text="&#xE11A;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#555555"/>
                                                </Button>
                                            </Grid>
                                        </Border>

                                        <Grid Grid.Row="3" Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="2"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" x:Name="BtnSpatial" Content="空间数据管理" Click="SwitchToSpatial" Height="26" FontSize="10" Padding="8,0">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="#1565C0"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Cursor" Value="Hand"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Grid.Column="2" x:Name="BtnAttribute" Content="属性数据管理" Click="SwitchToAttribute" Height="26" FontSize="10" Padding="8,0">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="#E8E8E8"/>
                                                        <Setter Property="Foreground" Value="#555555"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Cursor" Value="Hand"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>

                                        <TreeView Grid.Row="4" x:Name="DataTree" BorderThickness="0" Background="Transparent" FontSize="12"
                                                  ItemContainerStyle="{StaticResource DataTreeItemStyle}"/>
                                    </Grid>
                                </Border>
                            </avalonDock:LayoutAnchorable>
                        </avalonDock:LayoutAnchorablePane>

                        <!-- ====== 中间：地图区 ====== -->
                        <avalonDock:LayoutDocumentPane>
                            <avalonDock:LayoutDocument Title="地图视图" CanClose="False" ContentId="MapView">
                                <views:MapView x:Name="MapViewControl"/>
                            </avalonDock:LayoutDocument>
                        </avalonDock:LayoutDocumentPane>

                        <!-- ====== 右侧：图层面板 + 符号面板 + 地理处理面板 ====== -->
                        <avalonDock:LayoutAnchorablePane DockWidth="220" DockMinWidth="150">

                            <!-- 图层面板 -->
                            <avalonDock:LayoutAnchorable x:Name="LayerPanelAnchor" Title="图层" CanClose="False" ContentId="LayerPanel">
                                <Border Style="{StaticResource PanelBorderStyle}">
                                    <TreeView x:Name="LayerTreeView" Background="Transparent" BorderThickness="0"
                                              FontSize="11" AllowDrop="True" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              ItemContainerStyle="{StaticResource LayerTreeItemStyle}"
                                              ItemTemplate="{StaticResource LayerTreeTemplate}"/>
                                </Border>
                            </avalonDock:LayoutAnchorable>

                            <!-- 符号面板 -->
                            <avalonDock:LayoutAnchorable x:Name="SymbolPanelAnchor" Title="符号系统" ContentId="SymbolPanel">
                                <Border Style="{StaticResource PanelBorderStyle}">
                                    <StackPanel x:Name="SymbolEditorHost" Margin="0,0,0,4"/>
                                </Border>
                            </avalonDock:LayoutAnchorable>

                            <!-- 地理处理面板 -->
                            <avalonDock:LayoutAnchorable x:Name="GeoPanelAnchor" Title="地理处理" ContentId="GeoPanel">
                                <Border Style="{StaticResource PanelBorderStyle}">
                                    <ContentControl x:Name="GeoPanelContent"/>
                                </Border>
                            </avalonDock:LayoutAnchorable>

                        </avalonDock:LayoutAnchorablePane>

                    </avalonDock:LayoutPanel>
                </avalonDock:LayoutRoot>
            </avalonDock:DockingManager>

            <!-- 状态栏 -->
            <StatusBar Grid.Row="3" Background="#F2F2F2" Padding="6,2" FontSize="10">
                <StatusBar.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                        </Grid>
                    </ItemsPanelTemplate>
                </StatusBar.ItemsPanel>
                <StatusBarItem Grid.Column="0">
                    <TextBlock x:Name="StatusBar1" Text="就绪" Foreground="#555555"/>
                </StatusBarItem>
                <StatusBarItem Grid.Column="1">
                    <TextBlock x:Name="StatusScale" Text="比例 1:50000" Foreground="#555555" Margin="6,0"/>
                </StatusBarItem>
                <StatusBarItem Grid.Column="2">
                    <TextBlock x:Name="StatusCoord" Text="113.00° E  27.90° N" Foreground="#555555" Margin="6,0"/>
                </StatusBarItem>
            </StatusBar>
        </Grid>
    </Border>
</Window>
