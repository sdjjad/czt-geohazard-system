<UserControl x:Class="cztApp1.Views.GeoProcessToolView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent" FontFamily="Microsoft YaHei UI">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="4,2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/><!-- 0: 标题+刷新 -->
                <RowDefinition Height="Auto"/><!-- 1: 分类面图层 -->
                <RowDefinition Height="Auto"/><!-- 2: 灾害点图层 -->
                <RowDefinition Height="Auto"/><!-- 3: 分类字段 -->
                <RowDefinition Height="Auto"/><!-- 4: 分级分区 -->
                <RowDefinition Height="Auto"/><!-- 5: 分析方法 -->
                <RowDefinition Height="Auto"/><!-- 6: 输出 -->
                <RowDefinition Height="Auto"/><!-- 7: 按钮 -->
                <RowDefinition Height="Auto"/><!-- 8: 进度 -->
                <RowDefinition Height="*"/>    <!-- 9: 结果 -->
            </Grid.RowDefinitions>

            <!-- 0. 标题 + 刷新 -->
            <Grid Grid.Row="0" Margin="0,2,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="ToolDesc" Text="" FontSize="10"
                           Foreground="#666" TextWrapping="Wrap"
                           Visibility="Collapsed"/>
                <Button Grid.Column="1" Content="🔄" Width="26" Height="22" FontSize="11"
                        Click="Refresh_Click" Background="#E8E8E8" BorderThickness="0"
                        Cursor="Hand" ToolTip="刷新图层列表和字段"/>
            </Grid>

            <!-- 1. 分类面图层 -->
            <TextBlock Grid.Row="1" Text="分类面图层" FontSize="11" FontWeight="SemiBold"
                       Foreground="#333" Margin="0,0,0,2"/>
            <ComboBox Grid.Row="1" x:Name="ClassLayerCombo" Height="26" FontSize="10" Margin="0,0,0,8"
                      SelectionChanged="LayerCombo_SelectionChanged"/>

            <!-- 2. 灾害点图层 -->
            <TextBlock Grid.Row="2" Text="灾害点图层" FontSize="11" FontWeight="SemiBold"
                       Foreground="#333" Margin="0,0,0,2"/>
            <ComboBox Grid.Row="2" x:Name="HazardLayerCombo" Height="26" FontSize="10" Margin="0,0,0,8"/>

            <!-- 3. 分类字段 -->
            <TextBlock Grid.Row="3" Text="分类字段" FontSize="11" FontWeight="SemiBold"
                       Foreground="#333" Margin="0,0,0,2"/>
            <ComboBox Grid.Row="3" x:Name="ClassFieldCombo" Height="26" FontSize="10" Margin="0,0,0,8"/>

            <!-- 4. 分级分区 -->
            <TextBlock Grid.Row="4" Text="分级分区" FontSize="11" FontWeight="SemiBold"
                       Foreground="#333" Margin="0,0,0,2"/>
            <StackPanel Grid.Row="4" Margin="0,0,0,8">
                <ComboBox x:Name="ClassMethod" Height="26" FontSize="10" Margin="0,0,0,4"
                          SelectionChanged="ClassMethod_SelectionChanged">
                    <ComboBoxItem IsSelected="True">不分类（按字段原值）</ComboBoxItem>
                    <ComboBoxItem>自然间断点分级法</ComboBoxItem>
                    <ComboBoxItem>等间距分级</ComboBoxItem>
                    <ComboBoxItem>分位数分级</ComboBoxItem>
                    <ComboBoxItem>标准差分级</ComboBoxItem>
                </ComboBox>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="分类数" FontSize="10" Foreground="#555" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox Grid.Column="1" x:Name="ClassCountCombo" Height="24" FontSize="10" Width="60">
                        <ComboBoxItem>3</ComboBoxItem>
                        <ComboBoxItem>4</ComboBoxItem>
                        <ComboBoxItem IsSelected="True">5</ComboBoxItem>
                        <ComboBoxItem>7</ComboBoxItem>
                        <ComboBoxItem>10</ComboBoxItem>
                    </ComboBox>
                </Grid>
            </StackPanel>

            <!-- 5. 分析方法 -->
            <TextBlock Grid.Row="5" Text="分析方法" FontSize="11" FontWeight="SemiBold"
                       Foreground="#333" Margin="0,0,0,2"/>
            <ComboBox Grid.Row="5" x:Name="ModelMethod" Height="26" FontSize="10" Margin="0,0,0,8">
                <ComboBoxItem IsSelected="True">CF值法（确定性系数）</ComboBoxItem>
                <ComboBoxItem>信息量法</ComboBoxItem>
            </ComboBox>

            <!-- 6. 输出 -->
            <TextBlock Grid.Row="6" Text="输出目录" FontSize="11" FontWeight="SemiBold"
                       Foreground="#333" Margin="0,0,0,2"/>
            <Grid Grid.Row="6" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="OutputFolder" Height="26" FontSize="10"
                         Text="D:\GeoHazardOutput" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="📁" Width="26" Height="26" FontSize="12"
                        Click="BrowseFolder_Click" Background="#E8E8E8" BorderThickness="0"
                        Cursor="Hand" Margin="3,0,0,0"/>
            </Grid>

            <!-- 7. 按钮 -->
            <StackPanel Grid.Row="7" x:Name="ButtonBar" Orientation="Horizontal" Margin="0,2,0,8">
                <Button Content="运行分析" Width="90" Height="30" FontSize="11"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="RunAnalysis_Click" FontWeight="SemiBold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8,4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="保存结果" Width="90" Height="30" FontSize="11"
                        Background="#43A047" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="SaveResults_Click" Margin="6,0,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8,4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <!-- 8. 进度 -->
            <TextBlock Grid.Row="8" x:Name="ProgressText" Text=""
                       FontSize="10" Foreground="#1565C0" Margin="0,0,0,4"
                       Visibility="Collapsed" TextWrapping="Wrap"/>

            <!-- 9. 结果 -->
            <Border Grid.Row="9" Background="#FAFAFA" CornerRadius="4" Margin="0,2,0,0" Padding="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" x:Name="ResultLabel" Text="分析结果"
                               FontSize="10" Foreground="#555" FontWeight="SemiBold"
                               Margin="2,2,2,4"/>

                    <Border Grid.Row="1" x:Name="ChartContainer" Background="White"
                            BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="3"
                            Height="160" Margin="2,0,2,4" Visibility="Collapsed">
                        <Canvas x:Name="ChartCanvas"/>
                    </Border>

                    <Border Grid.Row="2" x:Name="CfSummaryContainer" Background="White"
                            BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="3"
                            Padding="6,4" Margin="2,0,2,4" Visibility="Collapsed">
                        <StackPanel x:Name="CfSummaryPanel"/>
                    </Border>

                    <DataGrid Grid.Row="3" x:Name="ResultGrid" AutoGenerateColumns="False"
                              Background="White" BorderBrush="#E0E0E0" FontSize="9"
                              IsReadOnly="True" Margin="2,0,2,2"
                              HeadersVisibility="Column" MaxHeight="250"
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              AlternatingRowBackground="#F8F8F8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="分级分类" Binding="{Binding ClassName}" Width="100"/>
                            <DataGridTextColumn Header="面积(km²)" Binding="{Binding ClassAreaKm2}" Width="60"/>
                            <DataGridTextColumn Header="灾害数" Binding="{Binding HazardCount}" Width="48"/>
                            <DataGridTextColumn Header="密度" Binding="{Binding Density}" Width="45"/>
                            <DataGridTextColumn Header="占比(%)" Binding="{Binding Percentage}" Width="48"/>
                            <DataGridTextColumn Header="CF值" Binding="{Binding CF}" Width="52">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#1565C0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="易发性" Width="60">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="CF" Converter="{StaticResource CfToRiskConverter}"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
