<UserControl x:Class="cztApp1.Views.GeoProcessToolView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent" FontFamily="Microsoft YaHei UI">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="4,2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ====== 0. 工具描述 ====== -->
            <TextBlock Grid.Row="0" x:Name="ToolDesc" Text="" FontSize="9"
                       Foreground="#888888" TextWrapping="Wrap" Margin="0,2,0,6"
                       Visibility="Collapsed"/>

            <!-- ====== 1. 数据源 ====== -->
            <TextBlock Grid.Row="1" Text="📂 数据源" FontSize="11" FontWeight="SemiBold"
                       Foreground="#333333" Margin="0,6,0,2"/>
            <ComboBox Grid.Row="2" x:Name="DataSource" Height="26" FontSize="10">
                <ComboBoxItem IsSelected="True">本地文件</ComboBoxItem>
                <ComboBoxItem>数据库</ComboBoxItem>
                <ComboBoxItem>在线服务(WMS/WFS)</ComboBoxItem>
            </ComboBox>

            <!-- ====== 2. 数据范围 ====== -->
            <TextBlock Grid.Row="3" Text="📍 数据范围" FontSize="11" FontWeight="SemiBold"
                       Foreground="#333333" Margin="0,6,0,2"/>
            <ComboBox Grid.Row="4" x:Name="DataRange" Height="26" FontSize="10"
                      SelectionChanged="DataRange_Changed">
                <ComboBoxItem IsSelected="True">长株潭全域</ComboBoxItem>
                <ComboBoxItem>长沙市</ComboBoxItem>
                <ComboBoxItem>株洲市</ComboBoxItem>
                <ComboBoxItem>湘潭市</ComboBoxItem>
                <ComboBoxItem>自定义范围</ComboBoxItem>
            </ComboBox>

            <!-- ====== 3. 数据时间 ====== -->
            <TextBlock Grid.Row="5" Text="📅 数据时间" FontSize="11" FontWeight="SemiBold"
                       Foreground="#333333" Margin="0,6,0,2"/>
            <ComboBox Grid.Row="6" x:Name="DataTime" Height="26" FontSize="10">
                <ComboBoxItem IsSelected="True">2020年</ComboBoxItem>
                <ComboBoxItem>2015年</ComboBoxItem>
                <ComboBoxItem>2010年</ComboBoxItem>
                <ComboBoxItem>2005年</ComboBoxItem>
                <ComboBoxItem>2000年</ComboBoxItem>
            </ComboBox>

            <!-- ====== 4. 分析方法（仅实装工具显示）===== -->
            <Grid Grid.Row="7" x:Name="AnalysisSection" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 分析方法 -->
                <TextBlock Grid.Row="0" Text="🔬 分析方法" FontSize="11" FontWeight="SemiBold"
                           Foreground="#333333" Margin="0,6,0,2"/>
                <ComboBox Grid.Row="1" x:Name="ModelMethod" Height="26" FontSize="10"/>

                <!-- 分级方法 -->
                <TextBlock Grid.Row="2" Text="📊 分级方法" FontSize="11" FontWeight="SemiBold"
                           Foreground="#333333" Margin="0,6,0,2"/>
                <ComboBox Grid.Row="3" x:Name="ClassificationMethod" Height="26" FontSize="10"
                          SelectionChanged="ClassificationMethod_Changed">
                    <ComboBoxItem IsSelected="True">自然断点法</ComboBoxItem>
                    <ComboBoxItem>等间距法</ComboBoxItem>
                    <ComboBoxItem>分位数法</ComboBoxItem>
                    <ComboBoxItem>标准偏差法</ComboBoxItem>
                    <ComboBoxItem>手动分级</ComboBoxItem>
                </ComboBox>

                <!-- 输出目录 -->
                <TextBlock Grid.Row="4" Text="💾 输出目录" FontSize="11" FontWeight="SemiBold"
                           Foreground="#333333" Margin="0,6,0,2"/>
                <Grid Grid.Row="5" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="OutputFolder" Height="26" FontSize="10"
                             Text="D:\GeoHazardOutput" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="📁" Width="26" Height="26" FontSize="12"
                            Click="BrowseFolder_Click" Background="#E8E8E8" BorderThickness="0"
                            Cursor="Hand" Margin="3,0,0,0" ToolTip="选择输出目录"/>
                </Grid>
            </Grid>

            <!-- ====== 5. 指标参数（仅实装工具显示）===== -->
            <StackPanel Grid.Row="8" x:Name="ParamSection" Visibility="Visible">
                <TextBlock Text="📋 指标参数" FontSize="11" FontWeight="SemiBold"
                           Foreground="#333333" Margin="0,6,0,2"/>
                <TextBlock Text="选择要分析的指标（可多选）：" FontSize="9"
                           Foreground="#999999" Margin="0,0,0,4"/>
                <ItemsControl x:Name="ParameterList" Margin="0,0,0,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FAFAFA" CornerRadius="3"
                                    BorderBrush="#E8E8E8" BorderThickness="1"
                                    Padding="6,3" Margin="0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" Content="{Binding Name}"
                                              IsChecked="{Binding IsSelected}"
                                              FontSize="10" Foreground="#333333"
                                              VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="分级数:" FontSize="9"
                                                   Foreground="#999999" Margin="4,0,2,0"
                                                   VerticalAlignment="Center"/>
                                        <ComboBox SelectedIndex="{Binding ClassCount, Converter={StaticResource CountToIndexConverter}}"
                                                  FontSize="9" Width="48" Height="20">
                                            <ComboBoxItem>3</ComboBoxItem>
                                            <ComboBoxItem>4</ComboBoxItem>
                                            <ComboBoxItem IsSelected="True">5</ComboBoxItem>
                                            <ComboBoxItem>6</ComboBoxItem>
                                            <ComboBoxItem>7</ComboBoxItem>
                                            <ComboBoxItem>8</ComboBoxItem>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- ====== 6. 占位提示 ====== -->
            <TextBlock Grid.Row="9" x:Name="PlaceholderMsg" Text="该工具开发中..."
                       FontSize="12" Foreground="#999999"
                       TextWrapping="Wrap" Margin="4,12,4,4"
                       Visibility="Collapsed"/>

            <!-- ====== 7. 操作按钮 ====== -->
            <StackPanel Grid.Row="10" x:Name="ButtonBar" Orientation="Horizontal"
                        Margin="0,6,0,6">
                <Button Content="▶ 运行分析" Width="100" Height="30" FontSize="11"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="RunAnalysis_Click" FontWeight="SemiBold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="4" Padding="8,4">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="💾 保存结果" Width="100" Height="30" FontSize="11"
                        Background="#43A047" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="SaveResults_Click" Margin="6,0,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="4" Padding="8,4">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="📄 打开报告" Width="100" Height="30" FontSize="11"
                        Background="#F0F0F0" Foreground="#333333" BorderThickness="0"
                        Cursor="Hand" Click="OpenReport_Click" Margin="6,0,0,0"
                        x:Name="OpenReportBtn" IsEnabled="False">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="4" Padding="8,4">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <!-- ====== 8. 进度提示 ====== -->
            <TextBlock Grid.Row="11" x:Name="ProgressText" Text=""
                       FontSize="10" Foreground="#1565C0" Margin="0,2,0,4"
                       Visibility="Collapsed"/>

            <!-- ====== 9. 结果区域 ====== -->
            <Border Grid.Row="12" x:Name="ResultSection" Background="#FAFAFA"
                    CornerRadius="4" Margin="0,4,0,0" Padding="4"
                    Visibility="Visible">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 结果标签 + 统计概览 -->
                    <Grid Grid.Row="0" Margin="2,2,2,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ResultLabel" Text="📊 分析结果"
                                   FontSize="10" Foreground="#555555"
                                   VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" x:Name="ResultSummary" Text=""
                                   FontSize="9" Foreground="#999999"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center" Margin="4,0"/>
                    </Grid>

                    <!-- 简易图表（Canvas绘制） -->
                    <Border Grid.Row="1" x:Name="ChartContainer" Background="White"
                            BorderBrush="#E0E0E0" BorderThickness="1"
                            CornerRadius="3" Height="180" Margin="2,2,2,4"
                            Visibility="Collapsed">
                        <Canvas x:Name="ChartCanvas"/>
                    </Border>

                    <!-- 结果表格 -->
                    <DataGrid Grid.Row="2" x:Name="ResultGrid"
                              AutoGenerateColumns="False"
                              Background="White" BorderBrush="#E0E0E0"
                              FontSize="9" IsReadOnly="True" Margin="2,2,2,2"
                              HeadersVisibility="Column"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              MaxHeight="300"
                              RowBackground="White"
                              AlternatingRowBackground="#F8F8F8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="分级分类" Binding="{Binding ClassName}"
                                                Width="120" FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="面积(km²)" Binding="{Binding ClassAreaKm2}"
                                                Width="70"/>
                            <DataGridTextColumn Header="灾害数" Binding="{Binding HazardCount}"
                                                Width="55"/>
                            <DataGridTextColumn Header="密度" Binding="{Binding Density}"
                                                Width="55"/>
                            <DataGridTextColumn Header="占比(%)" Binding="{Binding Percentage}"
                                                Width="55"/>
                            <DataGridTextColumn Header="CF值" Binding="{Binding CF}"
                                                Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#1565C0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="易发性" Width="70">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="CF" Converter="{StaticResource CfToRiskConverter}"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- CF汇总 -->
                    <Border Grid.Row="3" x:Name="CfSummaryContainer" Background="White"
                            BorderBrush="#E0E0E0" BorderThickness="1"
                            CornerRadius="3" Padding="6,4" Margin="2,4,2,2"
                            Visibility="Collapsed">
                        <StackPanel x:Name="CfSummaryPanel"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
