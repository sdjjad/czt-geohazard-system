<UserControl x:Class="cztApp1.Views.GeoProcessToolView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent" FontFamily="Microsoft YaHei UI">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="4,2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 0: 工具描述 -->
                <RowDefinition Height="Auto"/>  <!-- 1: 分类图层选择 -->
                <RowDefinition Height="Auto"/>  <!-- 2: 灾害点图层选择 -->
                <RowDefinition Height="Auto"/>  <!-- 3: 分类字段 -->
                <RowDefinition Height="Auto"/>  <!-- 4: 分析方法 -->
                <RowDefinition Height="Auto"/>  <!-- 5: 输出目录 -->
                <RowDefinition Height="Auto"/>  <!-- 6: 操作按钮 -->
                <RowDefinition Height="Auto"/>  <!-- 7: 进度 -->
                <RowDefinition Height="*"/>     <!-- 8: 结果区域 -->
            </Grid.RowDefinitions>

            <!-- 0. 工具描述 -->
            <TextBlock Grid.Row="0" x:Name="ToolDesc" Text="" FontSize="9"
                       Foreground="#888888" TextWrapping="Wrap" Margin="0,2,0,4"
                       Visibility="Collapsed"/>

            <!-- 1. 分类图层 -->
            <TextBlock Grid.Row="1" Text="📂 分类面图层" FontSize="11" FontWeight="SemiBold"
                       Foreground="#333333" Margin="0,6,0,2"/>
            <TextBlock Text="选择已加载的面图层作为分类数据源" FontSize="8" Foreground="#999" Margin="0,0,0,2"/>
            <ComboBox Grid.Row="1" x:Name="ClassLayerCombo" Height="26" FontSize="10" Margin="0,0,0,6"
                      SelectionChanged="LayerCombo_SelectionChanged"/>

            <!-- 2. 灾害点图层 -->
            <TextBlock Grid.Row="2" Text="📍 灾害点图层" FontSize="11" FontWeight="SemiBold"
                       Foreground="#333333" Margin="0,6,0,2"/>
            <TextBlock Text="选择已加载的点图层作为灾害数据源" FontSize="8" Foreground="#999" Margin="0,0,0,2"/>
            <ComboBox Grid.Row="2" x:Name="HazardLayerCombo" Height="26" FontSize="10" Margin="0,0,0,6"/>

            <!-- 3. 分类字段 -->
            <TextBlock Grid.Row="3" Text="🏷 分类字段" FontSize="11" FontWeight="SemiBold"
                       Foreground="#333333" Margin="0,6,0,2"/>
            <TextBlock Text="面图层中用于区分分类名称的属性字段" FontSize="8" Foreground="#999" Margin="0,0,0,2"/>
            <ComboBox Grid.Row="3" x:Name="ClassFieldCombo" Height="26" FontSize="10" Margin="0,0,0,6"/>

            <!-- 4. 分析方法 -->
            <TextBlock Grid.Row="4" Text="🔬 分析方法" FontSize="11" FontWeight="SemiBold"
                       Foreground="#333333" Margin="0,6,0,2"/>
            <ComboBox Grid.Row="4" x:Name="ModelMethod" Height="26" FontSize="10" Margin="0,0,0,6">
                <ComboBoxItem IsSelected="True">CF值法（确定性系数）</ComboBoxItem>
                <ComboBoxItem>信息量法</ComboBoxItem>
            </ComboBox>

            <!-- 5. 输出 -->
            <TextBlock Grid.Row="5" Text="💾 输出目录" FontSize="11" FontWeight="SemiBold"
                       Foreground="#333333" Margin="0,6,0,2"/>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="OutputFolder" Height="26" FontSize="10"
                         Text="D:\GeoHazardOutput" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="📁" Width="26" Height="26" FontSize="12"
                        Click="BrowseFolder_Click" Background="#E8E8E8" BorderThickness="0"
                        Cursor="Hand" Margin="3,0,0,0"/>
            </Grid>

            <!-- 6. 按钮 -->
            <StackPanel Grid.Row="6" x:Name="ButtonBar" Orientation="Horizontal" Margin="0,4,0,6">
                <Button Content="▶ 运行分析" Width="100" Height="30" FontSize="11"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="RunAnalysis_Click" FontWeight="SemiBold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8,4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="💾 保存结果" Width="100" Height="30" FontSize="11"
                        Background="#43A047" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="SaveResults_Click" Margin="6,0,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8,4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <!-- 7. 进度 -->
            <TextBlock Grid.Row="7" x:Name="ProgressText" Text=""
                       FontSize="10" Foreground="#1565C0" Margin="0,2,0,4"
                       Visibility="Collapsed" TextWrapping="Wrap"/>

            <!-- 8. 结果 -->
            <Border Grid.Row="8" Background="#FAFAFA" CornerRadius="4" Margin="0,4,0,0" Padding="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="2,2,2,4">
                        <TextBlock x:Name="ResultLabel" Text="📊 分析结果"
                                   FontSize="10" Foreground="#555" FontWeight="SemiBold"/>
                    </Grid>

                    <!-- 柱状图 -->
                    <Border Grid.Row="1" x:Name="ChartContainer" Background="White"
                            BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="3"
                            Height="160" Margin="2,0,2,4" Visibility="Collapsed">
                        <Canvas x:Name="ChartCanvas"/>
                    </Border>

                    <!-- CF汇总条 -->
                    <Border Grid.Row="2" x:Name="CfSummaryContainer" Background="White"
                            BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="3"
                            Padding="6,4" Margin="2,0,2,4" Visibility="Collapsed">
                        <StackPanel x:Name="CfSummaryPanel"/>
                    </Border>

                    <!-- 结果表格 -->
                    <DataGrid Grid.Row="3" x:Name="ResultGrid" AutoGenerateColumns="False"
                              Background="White" BorderBrush="#E0E0E0" FontSize="9"
                              IsReadOnly="True" Margin="2,0,2,2"
                              HeadersVisibility="Column" MaxHeight="250"
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              AlternatingRowBackground="#F8F8F8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="分级分类" Binding="{Binding ClassName}" Width="100"/>
                            <DataGridTextColumn Header="面积(km²)" Binding="{Binding ClassAreaKm2}" Width="65"/>
                            <DataGridTextColumn Header="灾害数" Binding="{Binding HazardCount}" Width="50"/>
                            <DataGridTextColumn Header="密度" Binding="{Binding Density}" Width="50"/>
                            <DataGridTextColumn Header="占比(%)" Binding="{Binding Percentage}" Width="50"/>
                            <DataGridTextColumn Header="CF值" Binding="{Binding CF}" Width="55">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#1565C0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="易发性" Width="65">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="CF" Converter="{StaticResource CfToRiskConverter}"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
