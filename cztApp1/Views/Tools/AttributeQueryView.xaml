<UserControl x:Class="cztApp1.Views.Tools.AttributeQueryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent" FontFamily="Microsoft YaHei UI">
    <Grid Margin="4,2">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🔍 属性查询" FontSize="11" FontWeight="SemiBold" Foreground="#333" Margin="0,2,0,4"/>

        <Grid Grid.Row="1" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="图层:" FontSize="10" Foreground="#555" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <ComboBox Grid.Column="1" x:Name="LayerCombo" Height="24" FontSize="10" SelectionChanged="LayerCombo_Changed"/>
            <Button Grid.Column="2" Content="🔄" Width="28" Height="24" FontSize="11"
                    Click="Refresh_Click" Background="#E8E8E8" BorderThickness="0"
                    Cursor="Hand" Margin="4,0,0,0" ToolTip="刷新图层列表"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,4">
            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Text="字段:" FontSize="10" Foreground="#555" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <ComboBox Grid.Column="1" x:Name="FieldCombo" Height="24" FontSize="10"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,4">
            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Text="条件:" FontSize="10" Foreground="#555" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <ComboBox x:Name="OperatorCombo" Height="24" FontSize="10" Width="60">
                <ComboBoxItem IsSelected="True">=</ComboBoxItem><ComboBoxItem>!=</ComboBoxItem>
                <ComboBoxItem>LIKE</ComboBoxItem><ComboBoxItem>&gt;</ComboBoxItem><ComboBoxItem>&lt;</ComboBoxItem>
            </ComboBox>
            <TextBox Grid.Column="2" x:Name="ValueBox" Height="24" FontSize="10" Margin="4,0,0,0"/>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,4,0,4">
            <Button Content="🔍 执行查询" Width="80" Height="26" FontSize="10"
                    Background="#1565C0" Foreground="White" BorderThickness="0" Cursor="Hand" Click="RunQuery_Click"/>
            <Button Content="清除" Width="50" Height="26" FontSize="10"
                    Background="#E8E8E8" BorderThickness="0" Cursor="Hand" Click="ClearQuery_Click" Margin="6,0,0,0"/>
            <TextBlock x:Name="ResultCount" Text="" FontSize="9" Foreground="#43A047" VerticalAlignment="Center" Margin="10,0,0,0"/>
        </StackPanel>

        <DataGrid Grid.Row="5" x:Name="ResultGrid" AutoGenerateColumns="True"
                  Background="White" BorderBrush="#E0E0E0" FontSize="10"
                  IsReadOnly="True" HeadersVisibility="Column" MaxHeight="300"
                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,4,0,0">
            <Button Content="💾 导出结果" Width="80" Height="26" FontSize="9"
                    Background="#43A047" Foreground="White" BorderThickness="0" Cursor="Hand" Click="ExportResult_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
