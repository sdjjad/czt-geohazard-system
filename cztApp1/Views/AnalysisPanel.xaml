<UserControl x:Class="cztApp1.Views.AnalysisPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White" FontFamily="Microsoft YaHei UI">

    <Border Background="White" Margin="8" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题 + 关闭 -->
            <Grid Grid.Row="0" Margin="12,10,12,6">
                <TextBlock x:Name="TitleText" Text="地质地震 — 分析参数设置"
                           FontSize="16" Foreground="#1A1A1A"/>
                <Button HorizontalAlignment="Right" Width="24" Height="24"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Click="Close_Click" Padding="0">
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#777777"/>
                </Button>
            </Grid>

            <!-- 参数设置区 -->
            <Border Grid.Row="1" Background="#FBFBFB" BorderBrush="#E0E0E0"
                    BorderThickness="1" CornerRadius="4" Margin="12,0,12,8" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="数据源：" VerticalAlignment="Center"
                               Foreground="#555555" FontSize="11" Margin="0,4"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="DataSource" Height="26"
                              Margin="0,4" FontSize="11">
                        <ComboBoxItem IsSelected="True">本地文件</ComboBoxItem>
                        <ComboBoxItem>数据库</ComboBoxItem>
                        <ComboBoxItem>在线服务</ComboBoxItem>
                    </ComboBox>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="数据范围：" VerticalAlignment="Center"
                               Foreground="#555555" FontSize="11" Margin="0,4"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="DataRange" Height="26"
                              Margin="0,4" FontSize="11">
                        <ComboBoxItem IsSelected="True">长株潭全域</ComboBoxItem>
                        <ComboBoxItem>长沙市</ComboBoxItem>
                        <ComboBoxItem>株洲市</ComboBoxItem>
                        <ComboBoxItem>湘潭市</ComboBoxItem>
                        <ComboBoxItem>自定义范围</ComboBoxItem>
                    </ComboBox>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="数据时间：" VerticalAlignment="Center"
                               Foreground="#555555" FontSize="11" Margin="0,4"/>
                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="DataTime" Height="26"
                              Margin="0,4" FontSize="11">
                        <ComboBoxItem IsSelected="True">2020-2025</ComboBoxItem>
                        <ComboBoxItem>2015-2020</ComboBoxItem>
                        <ComboBoxItem>2010-2020</ComboBoxItem>
                        <ComboBoxItem>2000-2025</ComboBoxItem>
                    </ComboBox>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="分析方法：" VerticalAlignment="Center"
                               Foreground="#555555" FontSize="11" Margin="0,4"/>
                    <ComboBox Grid.Row="3" Grid.Column="1" x:Name="ModelMethod" Height="26"
                              Margin="0,4" FontSize="11">
                        <ComboBoxItem IsSelected="True">CF值法</ComboBoxItem>
                        <ComboBoxItem>信息量法</ComboBoxItem>
                        <ComboBoxItem>证据权法</ComboBoxItem>
                        <ComboBoxItem>层次分析法</ComboBoxItem>
                    </ComboBox>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="输出目录：" VerticalAlignment="Center"
                               Foreground="#555555" FontSize="11" Margin="0,4"/>
                    <Grid Grid.Row="4" Grid.Column="1" Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="OutputFolder" Height="26" FontSize="11"
                                 Text="D:\GeoHazardOutput" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="..." Width="26" Height="26" FontSize="11"
                                Click="BrowseFolder_Click" Background="#E0E0E0" BorderThickness="0"
                                Cursor="Hand" Margin="4,0,0,0"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- 指标参数列表 -->
            <Border Grid.Row="2" Margin="12,0,12,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="指标参数" FontWeight="SemiBold"
                               FontSize="12" Foreground="#1A1A1A" Margin="0,0,0,6"/>
                    <ItemsControl Grid.Row="1" x:Name="ParameterList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}" IsChecked="True"
                                          FontSize="11" Foreground="#333333" Margin="0,2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- 结果区 -->
            <Border Grid.Row="3" Background="#FAFAFA" Margin="12,0,12,8" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="分析结果" FontWeight="SemiBold"
                               FontSize="12" Foreground="#1A1A1A" Margin="8,6,0,4"/>
                    <DataGrid Grid.Row="1" x:Name="ResultGrid" AutoGenerateColumns="True"
                              Background="White" BorderBrush="#E0E0E0" FontSize="10"
                              IsReadOnly="True" Margin="4,0,4,4"/>
                </Grid>
            </Border>

            <!-- 底部按钮 -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="12,4,12,10">
                <Button Content="运行分析" Width="100" Height="30" FontSize="11"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="RunAnalysis_Click" FontWeight="SemiBold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="3" Padding="6,2">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="保存结果" Width="100" Height="30" FontSize="11"
                        Background="#F0F0F0" Foreground="#333333" BorderThickness="0"
                        Cursor="Hand" Click="SaveResults_Click" Margin="8,0,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="3" Padding="6,2">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
