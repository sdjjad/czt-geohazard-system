<UserControl x:Class="cztApp1.Views.ThematicMapToolView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent" FontFamily="Microsoft YaHei UI">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 图层选择 -->
        <Grid Grid.Row="0" Margin="8,8,8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="制图图层" FontSize="11" Foreground="#333" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox Grid.Column="1" x:Name="LayerCombo" Height="26" FontSize="10"
                      SelectionChanged="LayerCombo_Changed"/>
        </Grid>

        <!-- 图名 -->
        <Grid Grid.Row="1" Margin="8,0,8,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="图名" FontSize="11" Foreground="#333" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Grid.Column="1" x:Name="MapTitle" Height="26" FontSize="10"
                     Text="长株潭地质灾害专题图"/>
        </Grid>

        <!-- 画布预览区：地图+图例+比例尺+指北针全部在此画布上自由拖动 -->
        <Border Grid.Row="2" x:Name="CanvasBorder" Margin="8,0,8,6"
                Background="White" BorderBrush="#C8C8C8" BorderThickness="1" CornerRadius="4"
                ClipToBounds="True">
            <Canvas x:Name="MainCanvas" Background="White" MinHeight="300"
                    SizeChanged="Canvas_SizeChanged"/>
        </Border>

        <!-- 按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="8,0,8,8">
            <Button Content="刷新底图" Width="72" Height="28" FontSize="10"
                    Background="#F0F0F0" Foreground="#333" BorderThickness="0"
                    Cursor="Hand" Click="RefreshMap_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#F5F5F5" CornerRadius="3" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#BBDEFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="生成专题图" Width="90" Height="28" FontSize="10"
                    Background="#1565C0" Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="GenerateMap_Click" Margin="6,0,0,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <TextBlock x:Name="StatusText" Text="" FontSize="10" Foreground="#555"
                       VerticalAlignment="Center" Margin="12,0,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
