<UserControl x:Class="cztApp1.Views.ThematicMapToolView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent" FontFamily="Microsoft YaHei UI">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="4,2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/><!-- 0: 制图图层 -->
                <RowDefinition Height="Auto"/><!-- 1: LayerCombo -->
                <RowDefinition Height="Auto"/><!-- 2: 图名 -->
                <RowDefinition Height="Auto"/><!-- 3: MapTitle -->
                <RowDefinition Height="Auto"/><!-- 4: 预览图框 -->
                <RowDefinition Height="*"/>   <!-- 5: 画布 -->
                <RowDefinition Height="Auto"/><!-- 6: 输出 -->
                <RowDefinition Height="Auto"/><!-- 7: 按钮 -->
                <RowDefinition Height="Auto"/><!-- 8: 状态 -->
            </Grid.RowDefinitions>

            <!-- 制图图层 -->
            <TextBlock Grid.Row="0" Text="🗺 制图图层" FontSize="11" FontWeight="SemiBold"
                       Foreground="#333" Margin="0,4,0,2"/>
            <ComboBox Grid.Row="1" x:Name="LayerCombo" Height="24" FontSize="10" Margin="0,0,0,4"
                      SelectionChanged="LayerCombo_Changed"/>

            <!-- 图名 -->
            <TextBlock Grid.Row="2" Text="📝 图名" FontSize="11" FontWeight="SemiBold"
                       Foreground="#333" Margin="0,4,0,2"/>
            <TextBox Grid.Row="3" x:Name="MapTitle" Height="26" FontSize="10"
                     Text="长株潭地质灾害专题图" Margin="0,0,0,4"/>

            <!-- 预览图框 -->
            <Border Grid.Row="4" x:Name="PreviewBorder" Background="White"
                    BorderBrush="#C0C0C0" BorderThickness="1" CornerRadius="3"
                    Height="200" Margin="0,0,0,6">
                <Canvas x:Name="PreviewCanvas" Background="White"
                        MouseLeftButtonDown="Canvas_MouseDown"
                        MouseMove="Canvas_MouseMove"
                        MouseLeftButtonUp="Canvas_MouseUp"/>
            </Border>

            <!-- 输出目录 -->
            <Grid Grid.Row="6" Margin="0,0,0,4">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="OutputFolder" Height="26" FontSize="10"
                         Text="D:\GeoHazardOutput\Maps" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="📁" Width="26" Height="26" FontSize="12"
                        Click="BrowseFolder_Click" Background="#E8E8E8" BorderThickness="0"
                        Cursor="Hand" Margin="3,0,0,0"/>
            </Grid>

            <!-- 操作按钮 -->
            <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="0,2,0,6">
                <Button Content="🗺 生成专题图" Width="110" Height="28" FontSize="10"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="GenerateMap_Click"/>
                <Button Content="🗑 清除画布" Width="80" Height="28" FontSize="10"
                        Background="#F0F0F0" Foreground="#333" BorderThickness="0"
                        Cursor="Hand" Click="ClearCanvas_Click" Margin="6,0,0,0"/>
                <Button Content="📂 打开目录" Width="80" Height="28" FontSize="10"
                        Background="#F0F0F0" Foreground="#333" BorderThickness="0"
                        Cursor="Hand" Click="OpenFolder_Click" Margin="6,0,0,0"/>
            </StackPanel>

            <!-- 状态 -->
            <Border Grid.Row="8" x:Name="StatusBorder" Background="#F8F8F8"
                    CornerRadius="3" Padding="6,4" Margin="0,2,0,0"
                    Visibility="Collapsed">
                <TextBlock x:Name="StatusText" Text="" FontSize="10"
                           Foreground="#1565C0" TextWrapping="Wrap"/>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
