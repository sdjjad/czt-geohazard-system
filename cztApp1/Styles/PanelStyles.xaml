<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        所有面板通用的外框格式
        使用方式：每个面板外层套一个 Border 引用此样式，标题栏用 PanelTitle + 三个 PanelIconBtn
    -->

    <!-- 面板外框：圆角、浅灰背景、焦点时蓝色边框 -->
    <Style x:Key="PanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="#FBFBFB"/>
        <Setter Property="BorderBrush" Value="#C8C8C8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Focusable" Value="True"/>
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="#64B5F6"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 面板标题文字 -->
    <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Foreground" Value="#1A1A1A"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- 面板标题栏右侧小按钮（⋮ ⤢ ✕） -->
    <Style x:Key="PanelIconBtnStyle" TargetType="Button">
        <Setter Property="Width" Value="22"/>
        <Setter Property="Height" Value="22"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="Transparent" CornerRadius="3" Padding="2">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#E0E0E0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
