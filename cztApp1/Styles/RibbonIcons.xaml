<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== 数据管理组 ===== -->

    <!-- 导入数据：文件夹+箭头 -->
    <Canvas x:Key="IconImport" Width="20" Height="18">
        <Path Fill="#1565C0" Data="M0,3 L0,15 L20,15 L20,5 L8,5 L6,3 Z"/>
        <Path Fill="#FFFFFF" Data="M7,7 L13,7 L13,12 L7,12 Z M10,6 L10,13 M7,9.5 L13,9.5"
              Stroke="#FFFFFF" StrokeThickness="1.2"/>
    </Canvas>

    <!-- 空间查询：放大镜+地图 -->
    <Canvas x:Key="IconSpatialQuery" Width="20" Height="20">
        <Path Fill="#1565C0" Data="M1,2 L13,2 L13,10 L1,10 Z" Stroke="#1565C0" StrokeThickness="1"/>
        <Path Fill="#1565C0" Data="M10,9 L18,17 L15,18 L8,11 Z"/>
        <Path Fill="#FFFFFF" Data="M3,4 L7,4 L7,7 L3,7 Z" Stroke="#FFFFFF" StrokeThickness="0.8"/>
    </Canvas>

    <!-- 空间分析：图层叠加 -->
    <Canvas x:Key="IconSpatialAnalysis" Width="20" Height="20">
        <Path Fill="#1565C0" Data="M2,2 L16,2 L16,7 L2,7 Z" Opacity="0.5"/>
        <Path Fill="#1565C0" Data="M1,7 L18,7 L18,12 L1,12 Z"/>
        <Path Fill="#1565C0" Data="M4,12 L14,12 L14,17 L4,17 Z" Opacity="0.7"/>
        <Path Data="M6,4 L12,4 M6,9 L12,9 M6,14 L10,14" Stroke="#FFFFFF" StrokeThickness="0.6"/>
    </Canvas>

    <!-- 制图：地图+圆规 -->
    <Canvas x:Key="IconMapping" Width="20" Height="20">
        <Path Fill="#1565C0" Data="M3,4 L17,4 L17,16 L3,16 Z" Stroke="#1565C0" StrokeThickness="1"/>
        <Path Fill="#FFFFFF" Data="M10,8 L14,12 M10,8 L6,14 M10,8 L14,8"
              Stroke="#1565C0" StrokeThickness="0.8"/>
    </Canvas>

    <!-- 属性浏览：表格 -->
    <Canvas x:Key="IconAttrBrowse" Width="20" Height="18">
        <Path Fill="#1565C0" Data="M0,2 L20,2 L20,16 L0,16 Z" Stroke="#1565C0" StrokeThickness="1"/>
        <Path Data="M0,7 L20,7 M7,2 L7,16" Stroke="#FFFFFF" StrokeThickness="1.2"/>
        <Path Data="M0,12 L20,12" Stroke="#FFFFFF" StrokeThickness="0.6"/>
    </Canvas>

    <!-- 属性查询：漏斗筛选 -->
    <Canvas x:Key="IconAttrQuery" Width="20" Height="20">
        <Path Fill="#1565C0" Data="M2,2 L18,2 L12,12 L12,18 L8,14 L8,12 Z" Stroke="#1565C0" StrokeThickness="1"/>
    </Canvas>

    <!-- 属性管理：铅笔 -->
    <Canvas x:Key="IconAttrManage" Width="18" Height="18">
        <Path Fill="#1565C0" Data="M3,13 L5,15 L14,4 L12,2 Z M2,14 L3.5,17 L6.5,15.5 Z"/>
        <Path Data="M5,15 L14,4" Stroke="#FFFFFF" StrokeThickness="0.5"/>
    </Canvas>

    <!-- ===== 土壤植被组 ===== -->

    <!-- 土壤类型：地层剖面 -->
    <Canvas x:Key="IconSoilType" Width="20" Height="20">
        <Path Fill="#795548" Data="M2,2 L18,2 L18,18 L2,18 Z"/>
        <!-- 地层纹理 -->
        <Path Data="M2,5 Q6,4 10,6 Q14,7 18,5" Stroke="#A1887F" StrokeThickness="1" Fill="none"/>
        <Path Data="M2,9 Q6,10 10,8 Q14,7 18,9" Stroke="#A1887F" StrokeThickness="1" Fill="none"/>
        <Path Data="M2,13 Q6,12 10,14 Q14,15 18,13" Stroke="#A1887F" StrokeThickness="1" Fill="none"/>
        <!-- 草叶 -->
        <Path Data="M8,2 L8,0 M10,2 L10,-1 M12,2 L12,0" Stroke="#4CAF50" StrokeThickness="1" Fill="none"/>
    </Canvas>

    <!-- 土壤湿度：水滴 -->
    <Canvas x:Key="IconSoilMoisture" Width="18" Height="20">
        <Path Fill="#0288D1" Data="M9,0 C4,7 1,11 1,15 C1,18 3,20 9,20 C15,20 17,18 17,15 C17,11 14,7 9,0 Z"/>
        <Path Fill="#FFFFFF" Data="M7,15 Q9,12 11,15 Q10,17 7,15" Opacity="0.5"/>
    </Canvas>

    <!-- 植被类型：树叶 -->
    <Canvas x:Key="IconVegType" Width="20" Height="20">
        <Path Fill="#2E7D32" Data="M10,1 Q18,3 19,10 Q15,12 10,19 Q5,12 1,10 Q2,3 10,1 Z"/>
        <Path Data="M10,1 L10,19 M10,7 L16,13 M10,12 L5,16" Stroke="#4CAF50" StrokeThickness="0.8" Fill="none"/>
    </Canvas>

    <!-- 植被覆盖度：网格+百分比 -->
    <Canvas x:Key="IconVegCoverage" Width="20" Height="20">
        <Path Fill="#43A047" Data="M1,2 L13,2 L13,14 L1,14 Z" Stroke="#43A047" StrokeThickness="1" Opacity="0.6"/>
        <Path Data="M1,2 L1,14 M4,2 L4,14 M7,2 L7,14 M10,2 L10,14 M13,2 L13,14
                  M1,2 L13,2 M1,6 L13,6 M1,10 L13,10 M1,14 L13,14"
              Stroke="#2E7D32" StrokeThickness="0.5" Fill="none"/>
        <Path Fill="#2E7D32" Data="M1,2 L5,2 L5,6 L1,6 Z"/>
        <Path Fill="#2E7D32" Data="M7,2 L9,2 L9,4 L7,4 Z"/>
        <Path Fill="#2E7D32" Data="M3,8 L7,8 L7,10 L3,10 Z"/>
        <Path Fill="#2E7D32" Data="M13,18 L15,18 L15,20 L13,20 Z"/>
        <Path Fill="#2E7D32" Data="M17,15 L19,15 L19,20 L17,20 Z"/>
        <Path Fill="#2E7D32" Data="M13,15 L15,15 L15,17 L13,17 Z"/>
    </Canvas>

    <!-- NDVI：光谱曲线 -->
    <Canvas x:Key="IconNDVI" Width="20" Height="18">
        <Path Data="M0,16 L4,12 L7,13 L10,5 L13,7 L16,1 L20,4"
              Stroke="#E53935" StrokeThickness="1.5" Fill="none" StrokeLineJoin="Round"/>
        <Path Data="M0,18 L20,18" Stroke="#BDBDBD" StrokeThickness="0.5"/>
        <Path Fill="#E53935" Data="M9,5 L11,3 L11,7 Z"/>
        <Path Fill="#E53935" Data="M3,12 L5,10 L5,14 Z"/>
        <Path Fill="#E53935" Data="M15,1 L17,-1 L17,3 Z"/>
    </Canvas>

    <!-- ===== 专题制图组 ===== -->

    <!-- 统计图：柱状图 -->
    <Canvas x:Key="IconStatChart" Width="20" Height="20">
        <Path Data="M0,18 L20,18" Stroke="#1565C0" StrokeThickness="1.2"/>
        <Path Fill="#1565C0" Data="M2,18 L2,8 L5,8 L5,18 Z M6,18 L6,4 L9,4 L9,18 Z M10,18 L10,11 L13,11 L13,18 Z M14,18 L14,3 L17,3 L17,18 Z"/>
    </Canvas>

    <!-- 统计表：数据表 -->
    <Canvas x:Key="IconStatTable" Width="20" Height="18">
        <Path Fill="#1565C0" Data="M0,0 L20,0 L20,16 L0,16 Z" Stroke="#1565C0" StrokeThickness="1"/>
        <Path Fill="#1565C0" Data="M0,0 L20,0 L20,4 L0,4 Z" Opacity="0.6"/>
        <Path Data="M6,0 L6,16 M13,0 L13,16" Stroke="#FFFFFF" StrokeThickness="1"/>
        <Path Data="M0,8 L20,8 M0,12 L20,12" Stroke="#FFFFFF" StrokeThickness="0.5"/>
    </Canvas>

    <!-- 专题图：地图+指北针 -->
    <Canvas x:Key="IconThematicMap" Width="20" Height="20">
        <Path Fill="#1565C0" Data="M2,3 L16,3 L16,14 L2,14 Z" Stroke="#1565C0" StrokeThickness="1"/>
        <Path Data="M4,6 L8,6 L8,9 L4,9 Z M10,6 L14,6 L14,9 L10,9 Z M4,10 L8,10 L8,12 L4,12 Z"
              Stroke="#FFFFFF" StrokeThickness="0.6" Fill="none"/>
        <Path Fill="#E53935" Data="M18,5 L20,1 L19,4 L16,3 Z"/>
    </Canvas>

</ResourceDictionary>
