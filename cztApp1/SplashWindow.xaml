<Window x:Class="cztApp1.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Width="480" Height="300" ResizeMode="NoResize"
        ShowInTaskbar="False" Topmost="True"
        FontFamily="Microsoft YaHei UI">

    <Window.Resources>
        <Storyboard x:Key="DotAnim" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot1" Storyboard.TargetProperty="Opacity" Duration="0:0:1.4">
                <LinearDoubleKeyFrame Value="0.25" KeyTime="0:0:0"/>
                <LinearDoubleKeyFrame Value="1.0" KeyTime="0:0:0.2"/>
                <LinearDoubleKeyFrame Value="0.25" KeyTime="0:0:0.6"/>
                <LinearDoubleKeyFrame Value="0.25" KeyTime="0:0:1.4"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot2" Storyboard.TargetProperty="Opacity" Duration="0:0:1.4">
                <LinearDoubleKeyFrame Value="0.25" KeyTime="0:0:0"/>
                <LinearDoubleKeyFrame Value="0.25" KeyTime="0:0:0.2"/>
                <LinearDoubleKeyFrame Value="1.0" KeyTime="0:0:0.4"/>
                <LinearDoubleKeyFrame Value="0.25" KeyTime="0:0:0.8"/>
                <LinearDoubleKeyFrame Value="0.25" KeyTime="0:0:1.4"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot3" Storyboard.TargetProperty="Opacity" Duration="0:0:1.4">
                <LinearDoubleKeyFrame Value="0.25" KeyTime="0:0:0"/>
                <LinearDoubleKeyFrame Value="0.25" KeyTime="0:0:0.4"/>
                <LinearDoubleKeyFrame Value="1.0" KeyTime="0:0:0.6"/>
                <LinearDoubleKeyFrame Value="0.25" KeyTime="0:0:1.0"/>
                <LinearDoubleKeyFrame Value="0.25" KeyTime="0:0:1.4"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>

    <Border CornerRadius="12" Background="#1B1F2B">
        <Border.Effect>
            <DropShadowEffect Color="#80000000" BlurRadius="30" ShadowDepth="6"/>
        </Border.Effect>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <Grid Width="72" Height="72" HorizontalAlignment="Center" Margin="0,0,0,22">
                <Ellipse Width="72" Height="72" Stroke="#1565C0" StrokeThickness="2" Fill="Transparent"/>
                <Ellipse Width="56" Height="56" Fill="#1565C0"/>
                <TextBlock Text="🗺" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

            <TextBlock Text="长株潭地质灾害发育特征专题系统——土壤植被" FontSize="18"
                       Foreground="#E8ECF0" FontWeight="Light"
                       HorizontalAlignment="Center" Margin="0,0,0,28" TextWrapping="Wrap"
                       TextAlignment="Center"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Ellipse x:Name="Dot1" Width="8" Height="8" Fill="#E8ECF0" Opacity="0.25" Margin="0,0,8,0"/>
                <Ellipse x:Name="Dot2" Width="8" Height="8" Fill="#E8ECF0" Opacity="0.25" Margin="0,0,8,0"/>
                <Ellipse x:Name="Dot3" Width="8" Height="8" Fill="#E8ECF0" Opacity="0.25"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
